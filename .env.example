# Anthropic — required for OM extraction
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Blob — auto-injected in Vercel deployments; set manually for local dev
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Supabase — Frontend (Vite build, exposed to browser — use anon key only)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase — API Routes (Vercel Functions, server-side only — NOT prefixed with VITE_)
# Needed in Phase 3 when API routes write directly to Supabase
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
